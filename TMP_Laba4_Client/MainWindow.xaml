<Window x:Class="TMP_Laba4_Client.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:lvc="clr-namespace:LiveChartsCore.SkiaSharpView.WPF;assembly=LiveChartsCore.SkiaSharpView.WPF"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        Title="Программа для обмена данными между компьютерами" 
        Height="545" Width="1200"
        WindowStyle="None" AllowsTransparency="True"
        Background="Transparent">

    <Window.Resources>
        <Style TargetType="Button" x:Key="RoundedButton">
            <Setter Property="Background" Value="DarkRed"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                            CornerRadius="5"
                            Margin="1"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                          VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Border Background="White" CornerRadius="5" BorderBrush="LightGray" BorderThickness="0">
        <DockPanel>
            <Border DockPanel.Dock="Top" Background="RoyalBlue" Height="32" CornerRadius="5,5,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <DockPanel>
                    <TextBlock Text="Программа для обмена данными между компьютерами" FontSize="14"
                               VerticalAlignment="Center" Margin="10,0" Foreground="White"/>

                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" Margin="3">

                        <Button Content="___" Click="Minimize_Click" Width="30" BorderThickness="1"
                                Background="RoyalBlue" Foreground="White" 
                                BorderBrush="White" Style="{StaticResource RoundedButton}"/>

                        <Button Content="□" Click="Maximize_Click" Width="30" BorderThickness="1"
                                Background="RoyalBlue" Foreground="White" 
                                BorderBrush="White" Style="{StaticResource RoundedButton}"/>

                        <Button Content="X" Click="Close_Click" Width="30" BorderThickness="1"
                                Background="Red" Foreground="White"
                                BorderBrush="White" Style="{StaticResource RoundedButton}"/>

                    </StackPanel>
                </DockPanel>
            </Border>

            <Grid Background="#FFECE9D8">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Top">
                        <StackPanel Width="330">
                            <ComboBox x:Name="PathFolders" 
                                        SelectionChanged="PathFolders_SelectionChanged"
                                        IsEditable="True"
                                        Margin="5 5 20 5" Height="20"/>

                            <ScrollViewer VerticalScrollBarVisibility="Auto"
                                            Margin="5 5 20 5" Height="370"
                                            Background="white">

                                <ItemsControl x:Name="FoldersList">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <TextBlock Text="{Binding}" FontSize="12" VerticalAlignment="Center"/>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </ScrollViewer>

                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="IP-адрес" 
                                            Margin="5" Padding="5 0 0 0" Width="90"/>

                                <TextBox Text="127.0.0.1" 
                                            Margin="5" Width="90"/>

                                <Button Content="Сервер отключить"
                                        Background="#FFECE9D8"
                                        Margin="5" Width="110"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Соединиться" 
                                        Margin="5" Width="90"
                                        Background="#FFECE9D8"/>

                                <Button Content="Отключиться"
                                        Background="#FFECE9D8"
                                        Margin="5 5 20 5" Width="90"/>

                                <Button Content="Выход" 
                                        Background="#FFECE9D8"
                                        Margin="20 5 0 5" Width="80"/>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <Button Content="Передать серверу" 
                                        Background="#FFECE9D8"
                                        Margin="5" Width="155"/>

                                <Button Content="Передать клиенту" 
                                        Background="#FFECE9D8"
                                        Margin="5" Width="155"/>

                            </StackPanel>
                        </StackPanel>

                        <StackPanel Width="320">
                            <TextBlock Text="Клиентская сторона"
                                        Margin="20 5 20 5" Height="20"/>

                            <RichTextBox Margin="20 5 20 5" Height="440"/>
                        </StackPanel>

                        <StackPanel Width="550">
                            <lvc:CartesianChart Height="225" Margin="20 20 5 10" 
                                                Series="{Binding Series}"/>

                            <lvc:CartesianChart Height="225" Margin="20 10 5 20"
                                            Series="{Binding Series}"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" DockPanel.Dock="Bottom"/>
                </DockPanel>
            </Grid>
        </DockPanel>
    </Border>
</Window>